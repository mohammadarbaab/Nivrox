<div class="cvh-wrapper">
  <video autoplay muted loop playsinline poster="{{ section.settings.poster_image | asset_url }}">
    {% if section.settings.video_url != blank %}
      <source src="{{ section.settings.video_url }}" type="video/mp4">
    {% elsif section.settings.video != blank %}
      <source src="{{ section.settings.video | asset_url }}" type="video/mp4">
    {% else %}
      <source src="{{ 'vidTrim.mp4' | asset_url }}" type="video/mp4">
    {% endif %}
  </video>

  <style>
    .cvh-wrapper {
      position: relative;
      width: 100%;
      height: 100vh;
      overflow: hidden;
    }

    .cvh-wrapper video {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    @media (max-width: 768px) {
      .cvh-wrapper {
        height: 70vh;
        min-height: 500px;
      }
    }

    @media (max-width: 480px) {
      .cvh-wrapper {
        height: 60vh;
        min-height: 450px;
      }
    }
  </style>
</div>

{% schema %}
{
  "name": "Custom Video Hero",
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Video File"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL (MP4)"
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "Poster Image (Recommended)"
    },
    {
      "type": "text",
      "id": "drop_tag",
      "label": "Drop Tag",
      "default": "Drop 2026"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Live. Now."
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Limited styles. Unlimited confidence."
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    }
  ],
  "presets": [
    {
      "name": "Custom Video Hero",
      "category": "Hero"
    }
  ]
}
{% endschema %}