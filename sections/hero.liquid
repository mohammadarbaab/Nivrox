{% assign section_id = 'new-collections-' | append: section.id %}

<section id="{{ section_id }}" class="new-collections">
  <div class="new-collections__inner">

    <button class="new-collections__arrow new-collections__arrow--prev" aria-label="Previous">
      &#8592;
    </button>

    <div class="new-collections__content">
      <h2 class="new-collections__title">{{ section.settings.title }}</h2>
      <p class="new-collections__description">{{ section.settings.description }}</p>

      <div class="new-collections__track-wrapper">
        <div class="new-collections__track">
          {% for block in section.blocks %}
            <div class="new-collections__item" {{ block.shopify_attributes }}>
              
              <!-- IMAGE -->
              <div class="new-collections__image-wrap">

                {% if block.settings.button_url != blank %}
                  <a href="{{ block.settings.button_url }}" class="new-collections__image-link">
                {% endif %}

                {% if block.settings.image != blank %}
                  <img
                    src="{{ block.settings.image | img_url: '600x800', crop: 'center' }}"
                    alt="{{ block.settings.item_title }}"
                    class="new-collections__image"
                    loading="lazy"
                    width="600"
                    height="800"
                  >
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'new-collections__placeholder' }}
                {% endif %}

                {% if block.settings.button_url != blank %}
                  </a>
                {% endif %}

              </div>

              <!-- CONTENT -->
              <div class="new-collections__item-body">
                <h3 class="new-collections__item-title">
                  {{ block.settings.item_title }}
                </h3>
                <p class="new-collections__item-desc">
                  {{ block.settings.item_description }}
                </p>
                {% if block.settings.button_url != blank %}
                  <a href="{{ block.settings.button_url }}" class="new-collections__link">
                    {{ block.settings.button_label }}
                  </a>
                {% endif %}
              </div>

            </div>
          {% endfor %}
        </div>
      </div>
    </div>

    <button class="new-collections__arrow new-collections__arrow--next" aria-label="Next">
      &#8594;
    </button>

  </div>
</section>

<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=Poppins:wght@300;400;500;600&display=swap');

/* Background */
#{{ section_id }} {
  background: linear-gradient(135deg, #f8f6f2 0%, #ece7df 100%);
  padding: 50px 20px 70px;
  overflow: hidden;
}

#{{ section_id }} .new-collections__inner {
  max-width: 1440px;
  margin: 0 auto;
  display: flex;
  align-items: flex-start;
}

#{{ section_id }} .new-collections__content {
  flex: 1;
  width: 100%;
}

/* Title */
#{{ section_id }} .new-collections__title {
  font-family: 'Playfair Display', serif;
  font-size: 52px;
  text-align: center;
  margin-bottom: 18px;
  font-weight: 600;
  letter-spacing: 1px;
  color: #2d2a26;
}

/* Description */
#{{ section_id }} .new-collections__description {
  text-align: center;
  max-width: 720px;
  margin: 0 auto 45px;
  font-size: 15px;
  color: #7a756d;
  line-height: 1.9;
  font-family: 'Poppins', sans-serif;
}

/* Track */
#{{ section_id }} .new-collections__track-wrapper {
  overflow: hidden;
}

#{{ section_id }} .new-collections__track {
  display: flex;
  gap: 30px;
  transition: transform 0.4s ease;
}

#{{ section_id }} .new-collections__item {
  flex: 0 0 calc((100% - 60px)/3);
  display: flex;
  flex-direction: column;
}

/* Image */
#{{ section_id }} .new-collections__image-wrap {
  aspect-ratio: 3/4;
  overflow: hidden;
  margin-bottom: 16px;
}

#{{ section_id }} .new-collections__image-link {
  display: block;
  height: 100%;
}

#{{ section_id }} .new-collections__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.6s ease;
  cursor: pointer;
}

/* Premium Hover Zoom */
#{{ section_id }} .new-collections__image-link:hover .new-collections__image {
  transform: scale(1.05);
}

/* Item Title */
#{{ section_id }} .new-collections__item-title {
  font-size: 14px;
  font-weight: 700;
  text-transform: uppercase;
  margin-bottom: 10px;
  letter-spacing: 1px;
  color: #2d2a26;
  font-family: 'Poppins', sans-serif;
}

/* Item Description */
#{{ section_id }} .new-collections__item-desc {
  font-size: 13px;
  color: #8a857d;
  margin-bottom: 16px;
  line-height: 1.7;
  font-family: 'Poppins', sans-serif;
}

/* Link */
#{{ section_id }} .new-collections__link {
  font-size: 12px;
  text-transform: uppercase;
  text-decoration: none;
  color: #2d2a26;
  font-weight: 600;
  letter-spacing: 1px;
  position: relative;
  font-family: 'Poppins', sans-serif;
}

#{{ section_id }} .new-collections__link::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: -4px;
  width: 100%;
  height: 1px;
  background-color: #2d2a26;
  transition: 0.3s ease;
}

#{{ section_id }} .new-collections__link:hover {
  color: #b48a5a;
}

#{{ section_id }} .new-collections__link:hover::after {
  background-color: #b48a5a;
}

/* Arrows */
#{{ section_id }} .new-collections__arrow {
  background: none;
  border: none;
  cursor: pointer;
  font-size: 26px;
  color: #b0aaa2;
  margin-top: 150px;
  transition: 0.3s ease;
}

#{{ section_id }} .new-collections__arrow:hover {
  color: #b48a5a;
}

/* Responsive */
@media (max-width: 1024px) {
  #{{ section_id }} .new-collections__item {
    flex: 0 0 calc((100% - 24px)/2);
  }
}

@media (max-width: 768px) {
  #{{ section_id }} .new-collections__item {
    flex: 0 0 100%;
  }
  #{{ section_id }} .new-collections__title,
  #{{ section_id }} .new-collections__description {
    display: none;
  }
}
</style>