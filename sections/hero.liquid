{% assign section_id = 'new-collections-' | append: section.id %}

<section id="{{ section_id }}" class="new-collections">
  <div class="new-collections__inner">

    <button class="new-collections__arrow new-collections__arrow--prev" aria-label="Previous">
      &#8592;
    </button>

    <div class="new-collections__content">
      <h2 class="new-collections__title">{{ section.settings.title }}</h2>
      <p class="new-collections__description">{{ section.settings.description }}</p>

      <div class="new-collections__track-wrapper">
        <div class="new-collections__track">
          {% for block in section.blocks %}
            <div class="new-collections__item" {{ block.shopify_attributes }}>
              <div class="new-collections__image-wrap">
                {% if block.settings.image != blank %}
                  <img
                    src="{{ block.settings.image | img_url: '600x800', crop: 'center' }}"
                    alt="{{ block.settings.item_title }}"
                    class="new-collections__image"
                    loading="lazy"
                    width="600"
                    height="800"
                  >
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'new-collections__placeholder' }}
                {% endif %}
              </div>

              <div class="new-collections__item-body">
                <h3 class="new-collections__item-title">
                  {{ block.settings.item_title }}
                </h3>
                <p class="new-collections__item-desc">
                  {{ block.settings.item_description }}
                </p>
                <a href="{{ block.settings.button_url }}" class="new-collections__link">
                  {{ block.settings.button_label }}
                </a>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>

    <button class="new-collections__arrow new-collections__arrow--next" aria-label="Next">
      &#8594;
    </button>

  </div>
</section>

<style>
#{{ section_id }} {
  background-color: #f0ede8;
  padding: 60px 0 80px;
  overflow: hidden;
}

#{{ section_id }} .new-collections__inner {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 60px;
  display: flex;
  align-items: flex-start;
}

#{{ section_id }} .new-collections__content {
  flex: 1;
  min-width: 0;
}

#{{ section_id }} .new-collections__title {
  font-family: Georgia, serif;
  font-size: 52px;
  text-align: center;
  margin-bottom: 24px;
}

#{{ section_id }} .new-collections__description {
  text-align: center;
  max-width: 600px;
  margin: 0 auto 48px;
  font-size: 14px;
  color: #888;
  line-height: 1.7;
}

#{{ section_id }} .new-collections__track-wrapper {
  overflow: hidden;
}

#{{ section_id }} .new-collections__track {
  display: flex;
  gap: 40px;
  transition: transform 0.4s ease;
}

#{{ section_id }} .new-collections__item {
  flex: 0 0 calc((100% - 80px) / 3);
  display: flex;
  flex-direction: column;
}

#{{ section_id }} .new-collections__image-wrap {
  aspect-ratio: 3/4;
  overflow: hidden;
  margin-bottom: 20px;
}

#{{ section_id }} .new-collections__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

#{{ section_id }} .new-collections__item-title {
  font-size: 13px;
  font-weight: 700;
  text-transform: uppercase;
  margin-bottom: 10px;
}

#{{ section_id }} .new-collections__item-desc {
  font-size: 13px;
  color: #888;
  margin-bottom: 16px;
}

#{{ section_id }} .new-collections__link {
  font-size: 12px;
  text-transform: uppercase;
  text-decoration: underline;
}

#{{ section_id }} .new-collections__arrow {
  background: none;
  border: none;
  cursor: pointer;
  font-size: 22px;
  padding: 0 15px;
  color: #aaa;
  margin-top: 220px;
}

#{{ section_id }} .new-collections__arrow:hover {
  color: #333;
}

/* Tablet */
@media (max-width: 992px) {
  #{{ section_id }} .new-collections__item {
    flex: 0 0 calc((100% - 24px) / 2);
  }
}

/* Mobile */
@media (max-width: 768px) {
  #{{ section_id }} .new-collections__arrow {
    display: none;
  }

  #{{ section_id }} .new-collections__item {
    flex: 0 0 100%;
  }
}
</style>

<script>
(function() {
  var section = document.getElementById('{{ section_id }}');
  if (!section) return;

  var track = section.querySelector('.new-collections__track');
  var items = section.querySelectorAll('.new-collections__item');
  var prevBtn = section.querySelector('.new-collections__arrow--prev');
  var nextBtn = section.querySelector('.new-collections__arrow--next');
  var currentIndex = 0;

  function getVisible() {
    if (window.innerWidth <= 768) return 1;
    if (window.innerWidth <= 992) return 2;
    return 3;
  }

  function updateSlider() {
    var itemWidth = items[0].offsetWidth;
    var gap = parseInt(getComputedStyle(track).gap) || 0;
    track.style.transform =
      'translateX(-' + currentIndex * (itemWidth + gap) + 'px)';
  }

  nextBtn.addEventListener('click', function() {
    var visible = getVisible();
    var maxIndex = items.length - visible;

    if (currentIndex >= maxIndex) {
      currentIndex = 0; // loop to start
    } else {
      currentIndex++;
    }
    updateSlider();
  });

  prevBtn.addEventListener('click', function() {
    var visible = getVisible();
    var maxIndex = items.length - visible;

    if (currentIndex <= 0) {
      currentIndex = maxIndex; // loop to end
    } else {
      currentIndex--;
    }
    updateSlider();
  });

  window.addEventListener('resize', function() {
    currentIndex = 0;
    updateSlider();
  });

})();
</script>